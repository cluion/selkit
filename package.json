{
  "name": "selkit",
  "version": "0.0.0",
  "private": true,
  "description": "The framework-agnostic select toolkit — headless select for JS, Vue & React.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "oxlint --deny-warnings",
    "typecheck": "turbo run typecheck",
    "size": "size-limit",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@size-limit/preset-small-lib": "^12.1.0",
    "oxlint": "^1.72.0",
    "size-limit": "^12.1.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "pnpm": {
    "overrides": {
      "vite": "^7"
    }
  }
}
