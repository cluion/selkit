{
  "name": "@selkit/react",
  "version": "0.2.0",
  "description": "React adapter for Selkit — useSyncExternalStore over @selkit/core.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --external react --external react-dom",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@selkit/core": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "axe-core": "^4.12.1",
    "jsdom": "^24.1.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.6"
  },
  "homepage": "https://cluion.github.io/selkit/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cluion/selkit.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/cluion/selkit/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
